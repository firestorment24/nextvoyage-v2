"use client";  
import Link from "next/link";  
import { usePathname } from "next/navigation";

export default function Navigation() {  
  const pathname = usePathname();  
  const links = [  
    { name: "The Reserve", href: "/reserve" },  
    { name: "The Perspective", href: "/perspective" },  
    { name: "The Archive", href: "/archive" },  
  ];

  return (  
    <nav className="fixed top-0 w-full z-50 bg-black/50 backdrop-blur-md border-b border-white/5">  
      <div className="container mx-auto px-6 h-20 flex items-center justify-between">  
        <Link href="/" className="font-serif text-xl tracking-[0.3em] uppercase hover:italic transition-all">  
          NexVoyage  
        </Link>  
        <div className="flex gap-12">  
          {links.map((link) => (  
            <Link   
              key={link.href}   
              href={link.href}  
              className={`font-sans text-[10px] uppercase tracking-[0.4em] transition-all hover:text-white ${pathname === link.href ? 'text-white underline underline-offset-8' : 'text-neutral-500'}`}  
            >  
              {link.name}  
            </Link>  
          ))}  
        </div>  
      </div>  
    </nav>  
  );  
}  
